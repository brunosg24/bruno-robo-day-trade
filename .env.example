# Environment Variables Template

# Set the following variables in your .env file

# API Key for accessing the trading platform
API_KEY="Your_API_Key_Here"

# Secret key for accessing secure API endpoints
SECRET_KEY="Your_Secret_Key_Here"

# Trading strategy to be used
TRADING_STRATEGY="Your_Strategy_Here"

# Frequency of trading (in seconds)
TRADING_FREQUENCY=60

# Maximum investment per trade
MAX_INVESTMENT=1000

# Logging level (debug, info, warning, error)
LOG_LEVEL="info"